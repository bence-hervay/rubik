digraph {

    graph [
        label="rubik",
        labelloc=t,

        pad=0.4,

        // Consider rendering the graph using a different layout algorithm, such as:
        // [dot, neato, twopi, circo, fdp, sfdp]
        layout=dot,
        overlap=false,
        splines="line",
        rankdir=LR,

        fontname="Helvetica", 
        fontsize="36",
    ];

    node [
        fontname="monospace",
        fontsize="10",
        shape="record",
        style="filled",
    ];

    edge [
        fontname="monospace",
        fontsize="10",
    ];

    "rubik" [label="crate|rubik", fillcolor="#5397c8"]; // "crate" node
    "rubik::algorithms" [label="pub mod|algorithms", fillcolor="#81c169"]; // "mod" node
